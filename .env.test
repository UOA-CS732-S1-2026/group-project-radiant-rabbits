# E2E Test Environment Variables
# Copy this file to .env.test for local E2E testing

# NextAuth config
AUTH_SECRET=your-secret-here
AUTH_GITHUB_ID=your-github-app-id
AUTH_GITHUB_SECRET=your-github-app-secret

# Database
MONGODB_URL=mongodb://localhost:27017/test

# Enable test mode (uses fake credentials instead of GitHub OAuth)
E2E_TEST_MODE=true
NEXT_PUBLIC_E2E_TEST_MODE=true

# Optional: customize test user ID
E2E_TEST_USER_ID=smoke-user-1
