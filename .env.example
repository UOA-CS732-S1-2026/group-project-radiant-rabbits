MONGODB_URL=replace-with-your-mongodb-connection-string

AUTH_SECRET=replace-with-long-random-secret
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Test mode for Playwright E2E (disables GitHub OAuth and enables test login provider)
TEST_MODE=false
NEXT_PUBLIC_TEST_MODE=false
TEST_USER_ID=test-user
TEST_USER_NAME=Playwright Test User
TEST_USER_EMAIL=playwright@test.local

# Optional AI provider for sprint review generation.
# Configure one provider. OpenAI is used first when both are present.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
